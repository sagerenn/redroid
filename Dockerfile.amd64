ARG BUILDPLATFORM
ARG BASE_IMAGE=redroid/redroid:13.0.0-latest

# ---------- Magisk (prebuilt APK; not compiled from Magisk sources) ----------
FROM --platform=$BUILDPLATFORM ubuntu:24.04 AS magisk

ENV DEBIAN_FRONTEND=noninteractive
RUN set -eux; \
    printf 'Acquire::Retries "5";\nAcquire::http::Timeout "30";\n' > /etc/apt/apt.conf.d/80-retries; \
    for i in 1 2 3 4 5; do apt-get update && break || sleep $((i * 5)); done; \
    apt-get install -y --no-install-recommends \
      ca-certificates curl default-jdk-headless apktool apksigner python3 unzip zip wget \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /magisk
COPY scripts/fetch-magisk-prebuilt.sh scripts/repack-magisk-manager.sh /magisk/
RUN chmod 755 /magisk/fetch-magisk-prebuilt.sh /magisk/repack-magisk-manager.sh && \
    MAGISK_PRIMARY_ABI=x86_64 MAGISK_SECONDARY_ABI=x86 MAGISK_OUT=/magisk \
      /magisk/fetch-magisk-prebuilt.sh && \
    /magisk/repack-magisk-manager.sh /magisk/magisk.apk /magisk/magisk-manager.apk

# ---------- ARM translation payload (for x86_64 hosts running arm64 apps) ----------
FROM --platform=$BUILDPLATFORM ubuntu:24.04 AS nativebridge

ENV DEBIAN_FRONTEND=noninteractive
RUN set -eux; \
    printf 'Acquire::Retries "5";\nAcquire::http::Timeout "30";\n' > /etc/apt/apt.conf.d/80-retries; \
    for i in 1 2 3 4 5; do apt-get update && break || sleep $((i * 5)); done; \
    apt-get install -y --no-install-recommends ca-certificates curl tar \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /native-bridge
RUN curl -fsSL https://raw.githubusercontent.com/zhouziyang/libndk_translation/master/libndk_translation-12.0.0.tar \
    | tar -xf -

# ---------- non-Zygisk hook tooling ----------
FROM --platform=$BUILDPLATFORM ubuntu:24.04 AS tools

ENV DEBIAN_FRONTEND=noninteractive
RUN set -eux; \
    printf 'Acquire::Retries "5";\nAcquire::http::Timeout "30";\n' > /etc/apt/apt.conf.d/80-retries; \
    for i in 1 2 3 4 5; do apt-get update && break || sleep $((i * 5)); done; \
    apt-get install -y --no-install-recommends ca-certificates curl xz-utils tar \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /tools
RUN mkdir -p android/x86_64 android/arm64 && \
    curl -fsSL https://github.com/frida/frida/releases/download/17.15.4/frida-server-17.15.4-android-x86_64.xz \
    | xz -d > android/x86_64/frida-server && \
    curl -fsSL https://github.com/gojue/ecapture/releases/download/v2.5.1/ecapture-v2.5.1-android-amd64.tar.gz \
    | tar -xz -C android/x86_64 --strip-components=1 && \
    curl -fsSL https://github.com/phudev95/magisk-a64dbg/archive/refs/heads/master.tar.gz \
    | tar -xz -C /tmp && \
    cp /tmp/magisk-a64dbg-master/files/a64dbg-server-x86_64/lldb-server android/x86_64/lldb-server && \
    curl -fsSL https://github.com/frida/frida/releases/download/17.15.4/frida-server-17.15.4-android-arm64.xz \
    | xz -d > android/arm64/frida-server && \
    curl -fsSL https://github.com/gojue/ecapture/releases/download/v2.5.1/ecapture-v2.5.1-android-arm64.tar.gz \
    | tar -xz -C android/arm64 --strip-components=1 && \
    curl -fsSL https://github.com/ShinoLeah/eDBG/releases/download/v2.3.0/eDBG_v2.3.0 \
    -o android/arm64/eDBG && \
    curl -fsSL https://github.com/LLeavesG/eBPFDexDumper/releases/download/v1.1.1/eBPFDexDumper-arm64 \
    -o android/arm64/eBPFDexDumper && \
    curl -fsSL https://github.com/SeeFlowerX/stackplz/releases/download/v3.0.3/stackplz \
    -o android/arm64/stackplz && \
    cp /tmp/magisk-a64dbg-master/files/a64dbg-server-arm64/lldb-server android/arm64/lldb-server && \
    chmod 755 android/x86_64/* android/arm64/* && \
    rm -rf /tmp/magisk-a64dbg-master

FROM --platform=$BUILDPLATFORM ubuntu:24.04 AS hooks

ENV DEBIAN_FRONTEND=noninteractive
RUN set -eux; \
    printf 'Acquire::Retries "5";\nAcquire::http::Timeout "30";\n' > /etc/apt/apt.conf.d/80-retries; \
    for i in 1 2 3 4 5; do apt-get update && break || sleep $((i * 5)); done; \
    apt-get install -y --no-install-recommends ca-certificates zip \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /hooks
COPY hooks/ /hooks/src/
RUN mkdir -p /hooks/out && \
    chmod 755 /hooks/src/redroid-hook.sh \
              /hooks/src/redroid_hook/service.sh \
              /hooks/src/redroid_hook/post-fs-data.sh && \
    (cd /hooks/src/redroid_hook && zip -qr /hooks/out/redroid_hook.zip . -x '*/zygisk/*') && \
    cp /hooks/src/redroid-hook.sh /hooks/out/redroid-hook.sh && \
    mkdir -p /hooks/out/configs && \
    cp -a /hooks/src/configs/. /hooks/out/configs/

# ---------- final: redroid base (from source when BASE_IMAGE is the CI-built tag) ----------
ARG BASE_IMAGE
FROM ${BASE_IMAGE}

COPY --from=nativebridge /native-bridge/system/bin/arm64/ /system/bin/arm64/
COPY --from=nativebridge /native-bridge/system/bin/ndk_translation_program_runner_binfmt_misc_arm64 /system/bin/ndk_translation_program_runner_binfmt_misc_arm64
COPY --from=nativebridge /native-bridge/system/etc/binfmt_misc/ /system/etc/binfmt_misc/
COPY --from=nativebridge /native-bridge/system/etc/init/ndk_translation.rc /system/etc/init/ndk_translation.rc
COPY --from=nativebridge /native-bridge/system/etc/ld.config.arm64.txt /system/etc/ld.config.arm64.txt
COPY --from=nativebridge /native-bridge/system/etc/cpuinfo.arm*.txt /system/etc/
COPY --from=nativebridge /native-bridge/system/lib64/arm64/ /system/lib64/arm64/
COPY --from=nativebridge /native-bridge/system/lib64/libndk_translation* /system/lib64/
COPY --from=nativebridge /native-bridge/system/lib64/libnb.so /system/lib64/libnb.so

COPY --from=magisk /magisk/magisk.apk /tmp/magisk.apk
COPY --from=magisk /magisk/magisk-manager.apk /tmp/magisk-manager.apk
COPY --from=magisk /magisk/runtime/ /system/etc/redroid/magisk/
COPY --from=magisk /magisk/magisk-prebuilt.env /system/etc/redroid/magisk-prebuilt.env
COPY --from=magisk /magisk/runtime/magisk /system/bin/magisk
COPY --from=magisk /magisk/runtime/magisk /system/bin/su
COPY --from=magisk /magisk/runtime/magisk /system/xbin/su
COPY magisk-boot/redroid-magisk-setup.sh /system/etc/redroid/redroid-magisk-setup.sh
COPY magisk-boot/redroid-magisk.rc /system/etc/init/redroid-magisk.rc
COPY --from=tools /tools/android/x86_64/ /data/local/tmp/tools/x86_64/
COPY --from=tools /tools/android/arm64/ /data/local/tmp/tools/arm64/
COPY --from=hooks /hooks/out/redroid-hook.sh /system/etc/redroid/hook/redroid-hook.sh
COPY --from=hooks /hooks/out/configs/ /system/etc/redroid/hook/configs/
COPY --from=hooks /hooks/out/redroid_hook.zip /system/etc/redroid/hook/redroid_hook.zip

ENV MAGISK_VER=prebuilt
ENV REDROID_GPU_MODE=guest
ENV REDROID_HOOK=non-zygisk
ENV REDROID_BASE=source

EXPOSE 5555

LABEL org.opencontainers.image.title="Redroid 13 with Magisk (AMD64 with ARM64 translation)"
LABEL org.opencontainers.image.description="Android 13 built from redroid/AOSP sources, Magisk prebuilt runtime, arm64 translation, non-Zygisk eBPF hook tooling"
LABEL org.opencontainers.image.version="13.0.0"
LABEL org.opencontainers.image.architecture="amd64"
LABEL magisk.included="true"
LABEL magisk.build="prebuilt"
LABEL redroid.build="source"
LABEL redroid.native_bridge="arm64"
LABEL redroid.hook="non-zygisk-ebpf"
